# Confluence Connection Settings
# Copy this file to .env and fill in your values
# ===============================================

# Your Confluence instance URL (Cloud or Server)
# Cloud: https://your-company.atlassian.net
# Server: https://confluence.your-company.com
CONFLUENCE_URL="https://your-company.atlassian.net"

# Your Confluence username (usually your email)
CONFLUENCE_USERNAME="your.email@company.com"

# Confluence API Token (NOT your password!)
# Get one at: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_PASSWORD="your_api_token_here"

# Default Confluence space key (optional)
CONFLUENCE_SPACE="DOCS"

# Default parent page for new documents (optional)
CONFLUENCE_PARENT="Documentation"

# ===============================================
# SECURITY NOTES:
# - NEVER commit .env file to git!
# - Add .env to your .gitignore
# - Rotate API tokens regularly
# - Use scoped tokens with minimal permissions
# ===============================================
